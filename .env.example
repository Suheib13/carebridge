# ─────────────────────────────────────────────
#  CareBridge — Environment Variables
#  Copy this file to .env.local and fill it in.
# ─────────────────────────────────────────────

# Supabase — required for auth, profiles, and medications
# Get these from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL="https://cnkqjevxtnggjeschbma.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_NijXwej1jIHQ0Qbcvw0NkQ_PZSCEyWx"

# Gemini AI — required for the AI symptom checker (server-side only, never expose to browser)
# Get your key from: https://aistudio.google.com/apikey
# Leave empty or omit if you don't have a key yet — the app will show a friendly unavailable message.
GEMINI_API_KEY="your-gemini-api-key"

# Express API server port (optional — defaults to 3001)
# API_PORT=3001
